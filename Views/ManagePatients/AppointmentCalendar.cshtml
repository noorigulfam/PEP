
@{
    ViewData["Title"] = "AppointmentCalendar";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<div class="container-fluid">

    @* <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-warning">📅 Appointment Calendar</h3>
        <span class="text-muted">View and manage your patient bookings</span>
    </div> *@

    <!-- Card -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">

            <h5 class="text-warning fw-semibold mb-3">
                Today's Appointments
            </h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">

                    <thead style="background-color:#d4af37; color:white;">
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Patient Name</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd MMM yyyy")</td>
                                    <td>@item.Date.ToString("hh:mm tt")</td>
                                    <td class="fw-semibold">@item.PatientName</td>
                                    <td>
                                        @if (item.Status == "Approved")
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                ✔ Approved
                                            </span>
                                        }
                                        else if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">
                                                ⏳ Pending
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2">
                                                ✖ Rejected
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-muted py-4">
                                    No appointments found
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>